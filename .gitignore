# Rust build output
target/

# Cargo lock is intentionally committed for reproducible builds

# Circom / snarkjs
circuits/node_modules/
# ptau ceremony files (large, reproducible from ceremony)
circuits/build/pot*.ptau
# intermediate compiler outputs (not needed at runtime)
circuits/build/*.r1cs
circuits/build/*.sym
# zkey phase 0 (pre-contribution, not the final proving key)
circuits/build/transfer_0.zkey
circuits/build/withdraw_0.zkey
# test circuit build artifacts (entirely generated)
circuits/test/build/

# circomlib is tracked as a git submodule
# (do not commit its .git directory or files directly)

# SDK / Frontend / Examples
packages/*/node_modules/
packages/*/dist/
packages/*/.next/
examples/*/node_modules/
examples/*/dist/

# Environment / secrets
.env
.env.local
*.env

# Claude Code
CLAUDE.md

# Editor
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db
